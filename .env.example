# App
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
# Comma-separated frontend origins (no trailing slash). Production example:
# CORS_ORIGINS=https://www.babulilmvirtualschool.com,https://babulilmvirtualschool.com
CORS_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql://babulilm:babulilm@localhost:5432/babulilm?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long
JWT_REFRESH_TTL=7d

# Cloudflare R2 (S3-compatible API; credentials from R2 API token with Object Read & Write)
# Cloudflare dashboard → R2 → account id in the S3 API URL
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET=babulilm-media
# Optional: full S3 API URL if not using the default endpoint for R2_ACCOUNT_ID
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_PRESIGN_EXPIRES_SECONDS=900

# R2 bucket CORS (Cloudflare dashboard → bucket → Settings → CORS policy)
# Required for browser presigned uploads (teacher CVs, course PDFs, etc.).
# Example AllowedOrigins: http://localhost:3000,https://www.babulilmvirtualschool.com

# Initial admin (used by prisma seed)
SEED_ADMIN_EMAIL=admin@babulilm.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FIRST_NAME=School
SEED_ADMIN_LAST_NAME=Admin
